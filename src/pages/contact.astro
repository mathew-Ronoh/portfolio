---
import BaseLayout from '../layouts/BaseLayout.astro'
import ContactForm from '../components/ContactForm.astro'
---

<BaseLayout title="Contact" description="Get in touch with Mathew Kiptoo">
  <section class="py-16 bg-gradient-to-br from-gray-50 to-blue-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Contact Me</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">I'd love to hear from you! Whether it's about opportunities, collaborations, or just a chat.</p>
    </div>
  </section>

  <ContactForm />
</BaseLayout>
