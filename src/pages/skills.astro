---
import BaseLayout from '../layouts/BaseLayout.astro'
import SkillsGrid from '../components/SkillsGrid.astro'
import data from '../data/portfolio.json'
---

<BaseLayout title="Skills" description="Technical skills and certifications of Mathew Kiptoo">
  <section class="py-16 bg-gradient-to-br from-gray-50 to-blue-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Skills & Certifications</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">Technical competencies, tools, and professional certifications I have acquired.</p>
    </div>
  </section>

  <SkillsGrid skills={data.skills} certifications={data.certifications} />
</BaseLayout>
