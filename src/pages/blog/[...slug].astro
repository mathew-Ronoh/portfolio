---
import BaseLayout from '../../layouts/BaseLayout.astro'
import type { GetStaticPaths } from 'astro'
import { BASE } from '../../config'
import data from '../../data/portfolio.json'

export const getStaticPaths = (() => {
  return data.blogTopics.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}) satisfies GetStaticPaths

const { post } = Astro.props
---

<BaseLayout title={post.title} description={post.description}>
  <article class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href={`${BASE}blog`} class="inline-flex items-center gap-1 text-blue-600 hover:underline mb-6">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        Back to Blog
      </a>
      <time class="text-sm text-gray-500">{post.date}</time>
      <h1 class="text-3xl font-bold text-gray-900 mt-2 mb-6">{post.title}</h1>
      <div class="prose max-w-none">
        <p class="text-lg text-gray-600 leading-relaxed">{post.description}</p>
        <div class="mt-8 p-6 bg-blue-50 rounded-xl border border-blue-100">
          <p class="text-gray-700">
            Thank you for reading! This article is a preview. I'm currently working on the full version.
            Stay connected on <a href={data.social.linkedin} class="text-blue-600 hover:underline" target="_blank">LinkedIn</a> 
            or <a href={data.social.twitter} class="text-blue-600 hover:underline" target="_blank">X</a> for updates.
          </p>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
