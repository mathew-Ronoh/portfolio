---
export interface Testimonial {
  name: string
  role: string
  text: string
  contact?: string
}

export interface Props {
  testimonials: Testimonial[]
}

const { testimonials } = Astro.props
---

<section class="py-16 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-gray-900 mb-10 text-center">Testimonials</h2>
    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <div class="bg-white rounded-xl shadow-md border border-gray-100 p-6 hover:shadow-lg transition">
          <div class="flex items-center gap-1 text-yellow-400 mb-4">
            {[...Array(5)].map((_, i) => (
              <svg key={i} class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-gray-600 italic mb-4">"{t.text}"</p>
          <div class="border-t pt-4">
            <p class="font-semibold text-gray-900">{t.name}</p>
            <p class="text-sm text-gray-500">{t.role}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
