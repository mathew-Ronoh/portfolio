---
import { BASE } from '../config'

const links = [
  { href: BASE, label: 'Home' },
  { href: `${BASE}experience`, label: 'Experience' },
  { href: `${BASE}projects`, label: 'Projects' },
  { href: `${BASE}skills`, label: 'Skills' },
  { href: `${BASE}education`, label: 'Education' },
  { href: `${BASE}testimonials`, label: 'Testimonials' },
  { href: `${BASE}blog`, label: 'Blog' },
  { href: `${BASE}contact`, label: 'Contact' },
]
---

<nav class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <a href={BASE} class="text-xl font-bold text-gray-900 hover:text-blue-600 transition">
        Mathew<span class="text-blue-600">.dev</span>
      </a>
      <div class="hidden md:flex items-center space-x-6">
        {links.map((link) => (
          <a href={link.href} class="nav-link">{link.label}</a>
        ))}
      </div>
      <button id="menu-toggle" class="md:hidden p-2 rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-100">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden pb-4 space-y-2">
      {links.map((link) => (
        <a href={link.href} class="block px-3 py-2 rounded-md text-gray-700 hover:bg-gray-100">{link.label}</a>
      ))}
    </div>
  </div>
</nav>

<style>
  .nav-link {
    color: #4b5563;
    font-weight: 500;
    font-size: 0.875rem;
    transition: color 0.15s ease;
  }
  .nav-link:hover {
    color: #2563eb;
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('mobile-menu')
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden')
    })
  }
</script>
