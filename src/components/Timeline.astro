---
export interface TimelineItem {
  degree?: string
  role?: string
  institution?: string
  organization?: string
  period: string
  description?: string
  status?: string
}

export interface Props {
  items: TimelineItem[]
  title: string
  type: 'education' | 'experience'
}

const { items, title, type } = Astro.props
---

<section class="py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-gray-900 mb-10 text-center">{title}</h2>
    <div class="relative">
      <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-blue-200"></div>
      <div class="space-y-10">
        {items.map((item) => (
          <div class="relative pl-20">
            <div class="absolute left-5 top-1 w-7 h-7 bg-blue-600 rounded-full border-4 border-white shadow flex items-center justify-center">
              {type === 'education' ? (
                <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path d="M12 14l9-5-9-5-9 5 9 5z" />
                  <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                </svg>
              ) : (
                <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              )}
            </div>
            <div class="bg-white rounded-lg shadow-md p-6 border border-gray-100 hover:shadow-lg transition">
              <span class="text-sm text-blue-600 font-medium">{item.period}</span>
              <h3 class="text-xl font-semibold text-gray-900 mt-1">{item.degree || item.role}</h3>
              <p class="text-gray-600 font-medium">{item.institution || item.organization}</p>
              {item.status && (
                <span class="inline-block mt-2 px-3 py-1 bg-green-100 text-green-700 text-xs font-medium rounded-full">{item.status}</span>
              )}
              {item.description && <p class="mt-3 text-gray-600">{item.description}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
